@model project_cvrde.Models.Complaint

@{
    ViewData["Title"] = "Complaint Details";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Complaint Details</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />
</head>

<body class="bg-light">

    <div class="container mt-5">

        <div class="row justify-content-center">

            <div class="col-lg-8">

                <div class="card shadow-lg border-0">

                    <div class="card-header bg-info text-white">

                        <h3 class="mb-0">
                            Complaint Details
                        </h3>

                    </div>

                    <div class="card-body">

                        <table class="table table-bordered table-striped">

                            <tr>
                                <th width="250">Complaint ID</th>
                                <td>@Model.ComplaintID</td>
                            </tr>

                            <tr>
                                <th>Employee ID</th>
                                <td>@Model.EmployeeID</td>
                            </tr>

                            <tr>
                                <th>Department ID</th>
                                <td>@Model.DepartmentID</td>
                            </tr>

                            <tr>
                                <th>Description</th>
                                <td>@Model.ComplaintDescription</td>
                            </tr>

                            <tr>
                                <th>Raised Date</th>
                                <td>@Model.RaisedDate.ToString("dd-MM-yyyy")</td>
                            </tr>

                            <tr>
                                <th>Expected Resolution Date</th>
                                <td>@Model.ExpectedResolutionDate.ToString("dd-MM-yyyy")</td>
                            </tr>

                            <tr>
                                <th>Status</th>
                                <td>

                                    @if (Model.Status == "Open")
                                    {
                                        <span class="badge bg-danger fs-6">
                                            Open
                                        </span>
                                    }
                                    else if (Model.Status == "Resolved")
                                    {
                                        <span class="badge bg-success fs-6">
                                            Resolved
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark fs-6">
                                            In Progress
                                        </span>
                                    }

                                </td>
                            </tr>

                            <tr>
                                <th>Priority</th>
                                <td>

                                    @if (Model.Priority == "High")
                                    {
                                        <span class="badge bg-danger fs-6">
                                            High
                                        </span>
                                    }
                                    else if (Model.Priority == "Medium")
                                    {
                                        <span class="badge bg-warning text-dark fs-6">
                                            Medium
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success fs-6">
                                            Low
                                        </span>
                                    }

                                </td>
                            </tr>

                        </table>

                        <div class="d-flex justify-content-between mt-4">

                            <a href="/Complaints"
                               class="btn btn-secondary">

                                ← Back

                            </a>

                            <div>

                                <a href="/Complaints/Edit/@Model.ComplaintID"
                                   class="btn btn-warning">

                                    Edit

                                </a>

                                <a href="/Complaints/Delete/@Model.ComplaintID"
                                   class="btn btn-danger">

                                    Delete

                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>