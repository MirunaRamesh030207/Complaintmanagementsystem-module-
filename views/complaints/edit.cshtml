@model project_cvrde.Models.Complaint

@{
    ViewData["Title"] = "Edit Complaint";
}

<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />

    <title>Edit Complaint</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

</head>

<body class="bg-light">

    <div class="container mt-5">

        <div class="row justify-content-center">

            <div class="col-lg-8">

                <div class="card shadow-lg border-0">

                    <div class="card-header bg-warning text-dark">

                        <h3 class="mb-0">
                            Edit Complaint
                        </h3>

                    </div>

                    <div class="card-body">

                        <form asp-action="Edit" method="post">

                            @Html.AntiForgeryToken()

                            <input asp-for="ComplaintID" type="hidden" />

                            <div class="row">

                                <div class="col-md-6 mb-3">

                                    <label class="form-label">
                                        Employee ID
                                    </label>

                                    <input asp-for="EmployeeID"
                                           class="form-control" />

                                    <span asp-validation-for="EmployeeID"
                                          class="text-danger"></span>

                                </div>

                                <div class="col-md-6 mb-3">

                                    <label class="form-label">
                                        Department ID
                                    </label>

                                    <input asp-for="DepartmentID"
                                           class="form-control" />

                                    <span asp-validation-for="DepartmentID"
                                          class="text-danger"></span>

                                </div>

                            </div>

                            <div class="mb-3">

                                <label class="form-label">
                                    Complaint Description
                                </label>

                                <textarea asp-for="ComplaintDescription"
                                          rows="4"
                                          class="form-control"></textarea>

                                <span asp-validation-for="ComplaintDescription"
                                      class="text-danger"></span>

                            </div>

                            <div class="row">

                                <div class="col-md-6 mb-3">

                                    <label class="form-label">
                                        Raised Date
                                    </label>

                                    <input asp-for="RaisedDate"
                                           type="date"
                                           class="form-control" />

                                </div>

                                <div class="col-md-6 mb-3">

                                    <label class="form-label">
                                        Expected Resolution Date
                                    </label>

                                    <input asp-for="ExpectedResolutionDate"
                                           type="date"
                                           class="form-control" />

                                </div>

                            </div>

                            <div class="row">

                                <div class="col-md-6 mb-3">

                                    <label class="form-label">
                                        Status
                                    </label>

                                    <select asp-for="Status"
                                            class="form-select">

                                        <option>Open</option>

                                        <option>In Progress</option>

                                        <option>Resolved</option>

                                    </select>

                                </div>

                                <div class="col-md-6 mb-3">

                                    <label class="form-label">
                                        Priority
                                    </label>

                                    <select asp-for="Priority"
                                            class="form-select">

                                        <option>High</option>

                                        <option>Medium</option>

                                        <option>Low</option>

                                    </select>

                                </div>

                            </div>

                            <hr />

                            <div class="d-flex justify-content-between">

                                <a href="/Complaints"
                                   class="btn btn-secondary">

                                    Back

                                </a>

                                <button type="submit"
                                        class="btn btn-warning">

                                    Update Complaint

                                </button>

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    

</body>
</html>